{
  "name": "uniclipboard",
  "private": true,
  "version": "0.16.0-alpha.1",
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "cross-env UNICLIPBOARD_ENV=development vite",
    "dev:sweep": "node -e \"try{require('child_process').execSync('cargo sweep --time 3 --target target',{stdio:'ignore'})}catch{}\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "version:bump": "node scripts/bump-version.js",
    "gen:openapi": "cargo run -p uc-webserver --bin gen-openapi",
    "gen:client": "openapi-ts",
    "gen:api": "bun run gen:openapi && bun run gen:client",
    "tauri": "tauri",
    "daemon:dev": "node scripts/prepare-daemon-sidecar.mjs --debug",
    "daemon:sidecar": "node scripts/prepare-daemon-sidecar.mjs",
    "tauri:dev": "cross-env UNICLIPBOARD_ENV=development UC_PROFILE=dev tauri dev",
    "tauri:build:dev": "bun run daemon:sidecar && tauri build --config src-tauri/tauri.dev.conf.json --features dev-profile",
    "tauri:dev:peerA": "cross-env UNICLIPBOARD_ENV=development UC_DISABLE_SINGLE_INSTANCE=1 UC_PROFILE=a UC_CLIPBOARD_MODE=full tauri dev",
    "tauri:dev:peerB": "cross-env UNICLIPBOARD_ENV=development UC_DISABLE_SINGLE_INSTANCE=1 UC_PROFILE=b UC_CLIPBOARD_MODE=passive tauri dev --config '{\"build\":{\"beforeDevCommand\":\"\"}}' --no-dev-server-wait",
    "tauri:dev:dual": "bun run daemon:dev && concurrently -k -n peerA,peerB \"bun run tauri:dev:peerA\" \"bun run tauri:dev:peerB\"",
    "tauri:dev:dual:kill": "echo 'Use Ctrl+C in tauri:dev:dual session to stop both peers.'",
    "test": "vitest",
    "test:coverage:frontend": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "prepare": "husky",
    "test:coverage": "cargo llvm-cov --html --workspace",
    "e2e:wdio": "wdio run e2e/wdio.conf.mjs",
    "e2e:card": "scripts/e2e/run-card.sh",
    "doctor": "npx react-doctor@latest"
  },
  "lint-staged": {
    "Cargo.toml": [
      "node scripts/refresh-agents-structure.mjs"
    ],
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.md": [
      "node scripts/fix-md-cjk-emphasis.mjs",
      "autocorrect --fix",
      "prettier --write"
    ],
    "*.{json,css,html}": [
      "prettier --write"
    ],
    "{apps,crates,src-tauri}/**/*.rs": [
      "rustfmt --edition 2021"
    ]
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/noto-sans-sc": "^5.2.10",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@reduxjs/toolkit": "^2.12.0",
    "@sentry/react": "^10.53.1",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-log": "2.8.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@types/culori": "^4.0.1",
    "culori": "^4.0.2",
    "framer-motion": "^12.38.0",
    "i18next": "^26.2.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.16.0",
    "next-themes": "^0.4.6",
    "pino": "^10.3.1",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-colorful": "^5.7.0",
    "react-dom": "^19.2.6",
    "react-hotkeys-hook": "^5.3.2",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.3.0",
    "react-resizable-panels": "^4.11.1",
    "react-router-dom": "^7.15.1",
    "react-virtuoso": "^4.18.7",
    "remark-gfm": "^4.0.1",
    "semver": "^7.7.4",
    "sonner": "^2.0.7",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@hey-api/openapi-ts": "0.97.3",
    "@react-grab/mcp": "^0.1.37",
    "@sentry/vite-plugin": "^5.3.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.11.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/mocha": "^10.0.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.7.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "4.1.6",
    "@wdio/cli": "^9.27.1",
    "@wdio/globals": "^9.27.1",
    "@wdio/local-runner": "^9.27.1",
    "@wdio/mocha-framework": "^9.27.1",
    "@wdio/spec-reporter": "^9.27.1",
    "autocorrect-node": "^2.14.0",
    "autoprefixer": "^10.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "glob": "^13.0.6",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.4",
    "mocha": "^10.8.2",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "react-grab": "^0.1.37",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6",
    "webdriverio": "^9.27.1"
  }
}
