{
  "$schema": "https://schema.tauri.app/config",
  "productName": "UniClipboard",
  "version": "0.16.0-alpha.8",
  "identifier": "app.uniclipboard.desktop",
  "build": {
    "beforeDevCommand": "bun run dev:sweep && bun run daemon:dev && bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "UniClipboard",
        "width": 800,
        "height": 600,
        "minWidth": 990,
        "minHeight": 660,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": true,
        "visible": false,
        "devtools": true,
        "windowEffects": {
          "effects": ["hudWindow"],
          "state": "active",
          "radius": 16
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "deb", "rpm", "appimage", "nsis"],
    "externalBin": ["binaries/uniclipd"],
    "category": "Utility",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["libayatana-appindicator3-1"],
        "desktopTemplate": "../packaging/linux/uniclipboard.desktop.hbs"
      },
      "rpm": {
        "depends": ["libayatana-appindicator-gtk3"],
        "desktopTemplate": "../packaging/linux/uniclipboard.desktop.hbs"
      }
    },
    "windows": {
      "nsis": {
        "installerHooks": "windows/installer-hooks.nsh"
      }
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://release.uniclipboard.app/stable.json?from={{current_version}}",
        "https://uniclipboard.github.io/UniClipboard/stable.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIyNjgwODM2ODY1QzI3MzgKUldRNEoxeUdOZ2hvc3RZOXRMNTRiOHBWQ1d2RkljN2ViTzlpRDExSHZmMmZxY01ZZW1Zd3RJV2IK"
    }
  }
}
